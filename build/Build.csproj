<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Self-hosted build script. References the published Tamp packages
    (not sibling-clone) so this is end-to-end dogfooding of Tamp.Core
    + Tamp.NetCli.V10. CI sets TampCoreMode=package so the wrapper
    csprojs also resolve Tamp.Core from nuget.org.
  -->

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Tamp.Core" />
    <PackageReference Include="Tamp.NetCli.V10" />
    <PackageReference Include="Tamp.Telegram" />
    <PackageReference Include="Tamp.SonarScanner.V10" />
  </ItemGroup>

</Project>
